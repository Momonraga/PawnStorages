<?xml version="1.0" encoding="utf-8"?>

<Defs>

    <JobDef>
        <defName>PS_Enter</defName>
        <driverClass>PawnStorages.JobDriver_Enter</driverClass>
        <reportString>Entering TargetA</reportString>
        <allowOpportunisticPrefix>true</allowOpportunisticPrefix>
    </JobDef>
    
    <JobDef>
        <defName>PS_CaptureAnimalToFarm</defName>
        <driverClass>PawnStorages.Farm.JobDriver_TakeToFarm</driverClass>
        <reportString>storing TargetA.</reportString>
        <alwaysShowWeapon>true</alwaysShowWeapon>
        <makeTargetPrisoner>false</makeTargetPrisoner>
        <casualInterruptible>false</casualInterruptible>
        <carryThingAfterJob>true</carryThingAfterJob>
    </JobDef>
    
    <JobDef>
        <defName>PS_RopeToFarm</defName>
        <driverClass>PawnStorages.Jobs.JobDriver_RopeToFarm</driverClass>
        <reportString>leading TargetA to farm.</reportString>
        <casualInterruptible>false</casualInterruptible>
        <allowOpportunisticPrefix>true</allowOpportunisticPrefix>
    </JobDef>
</Defs>
